{
  "apiToken": "your-api-token-here",
  "encryptionKey": "your-encryption-key-here",
  "claudePath": "/opt/homebrew/bin/claude",
  "listenAddr": "localhost:8080",
  "historyDB": "~/.tetora/history.db",
  "jobsFile": "~/.tetora/jobs.json",
  "knowledgeDir": "~/.tetora/knowledge",
  "workspaceDir": "~/.tetora/workspace",
  "runtimeDir": "~/.tetora/runtime",
  "vaultDir": "~/.tetora/vault",

  "allowedDirs": [
    "~/.tetora/workspace",
    "~/projects",
    "~/Documents"
  ],

  "defaultProvider": "qwen",
  "defaultModel": "auto",
  "defaultAgent": "coder",
  "defaultBudget": 10.0,
  "defaultTimeout": "2h",
  "defaultWorkdir": "~/.tetora/workspace",
  "defaultAddDirs": ["~/.tetora/workspace"],

  "providers": {
    "qwen": {
      "apiKey": "your-qwen-api-key",
      "path": "",
      "baseUrl": ""
    },
    "google": {
      "apiKey": "your-google-api-key"
    },
    "claude-code": {
      "path": "/opt/homebrew/bin/claude"
    }
  },

  "agents": {
    "coder": {
      "provider": "qwen",
      "model": "auto",
      "allowedDirs": ["~/projects"],
      "localModel": "qwen3.6-plus",
      "cloudModel": "claude-sonnet-4",
      "pinMode": ""
    },
    "writer": {
      "provider": "google",
      "model": "gemini-2.5-pro"
    }
  },

  "telegram": {
    "botToken": "your-telegram-bot-token",
    "chatID": 123456789
  },

  "discord": {
    "botToken": "your-discord-bot-token",
    "publicKey": "your-discord-public-key",
    "guildID": "your-guild-id",
    "channelIDs": {
      "general": "channel-id-1",
      "dev": "channel-id-2"
    },
    "claudePath": "/opt/homebrew/bin/claude",
    "terminal": {
      "claudePath": "/opt/homebrew/bin/claude"
    }
  },

  "oauth": {
    "encryptionKey": "your-oauth-encryption-key",
    "services": {
      "google": {
        "clientId": "your-google-client-id",
        "clientSecret": "your-google-client-secret"
      },
      "spotify": {
        "clientId": "your-spotify-client-id",
        "clientSecret": "your-spotify-client-secret"
      }
    }
  },

  "dashboardAuth": {
    "username": "admin",
    "password": "your-dashboard-password",
    "token": "your-dashboard-token"
  },

  "costAlert": {
    "dailyLimit": 50.0,
    "weeklyLimit": 200.0
  },
  "budgets": {
    "global": {
      "daily": 50.0,
      "weekly": 200.0,
      "monthly": 500.0
    }
  },

  "notifications": [
    {
      "type": "webhook",
      "webhookUrl": "https://your-webhook-url.com/notify"
    }
  ],

  "push": {
    "vapidPublicKey": "your-vapid-public-key",
    "vapidPrivateKey": "your-vapid-private-key"
  },

  "defaultClientID": "default",
  "clientsDir": "~/.tetora/clients",

  "todoist": {
    "apiKey": "your-todoist-api-key"
  },
  "notion": {
    "apiKey": "your-notion-api-key"
  },
  "browserRelay": {
    "token": "your-browser-relay-token"
  },

  "webhooks": [
    {
      "url": "https://your-webhook-url.com",
      "headers": {
        "Authorization": "Bearer your-webhook-token"
      }
    }
  ],

  "tls": {
    "certFile": "/path/to/cert.pem",
    "keyFile": "/path/to/key.pem"
  }
}
