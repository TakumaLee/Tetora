---
import { languages, type Lang } from '../i18n/ui';
interface Props { currentLang?: Lang; }
const { currentLang = 'en' } = Astro.props;
---
<div class="lang-bar">
  {Object.entries(languages).map(([code, label]) => (
    <a
      class:list={['lang-btn', { active: code === currentLang }]}
      href={code === 'en' ? '/' : `/${code}/`}
    >
      {label}
    </a>
  ))}
</div>
<script is:inline>
  document.querySelector('.lang-bar').addEventListener('click', function(e) {
    if (e.target.classList.contains('lang-btn')) {
      sessionStorage.setItem('lang_chosen', '1');
    }
  });
</script>
